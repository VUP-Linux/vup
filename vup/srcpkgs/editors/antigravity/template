# Template file for 'antigravity'
pkgname=antigravity
version=2.0.11
revision=1
archs="x86_64 aarch64"
create_wrksrc=yes
hostmakedepends="tar"
depends="
 alsa-lib
 at-spi2-core
 cairo
 cups
 dbus
 expat
 glib
 gtk+3
 libX11
 libXcomposite
 libXdamage
 libXext
 libXfixes
 libXrandr
 libXScrnSaver
 libdrm
 libsecret
 libxcb
 libxkbcommon
 libxkbfile
 libxshmfence
 lsof
 mesa
 nspr
 nss
 pango
 shared-mime-info
 xdg-utils
"
short_desc="Agentic development hub from Google"
maintainer="AmarBego <begovicamar@proton.me>"
license="custom:Google-Antigravity"
homepage="https://antigravity.google/"
restricted=yes
nopie=yes
nostrip=yes
noshlibprovides=yes

_build=6560309696135168
_baseurl="https://storage.googleapis.com/antigravity-public/antigravity-hub/${version}-${_build}"

case "$XBPS_TARGET_MACHINE" in
	x86_64)
		distfiles="${_baseurl}/linux-x64/Antigravity.tar.gz>${pkgname}-${version}-x64.tar.gz"
		checksum=a1b2b5bf0de5f4304c29897f81aa69cb8c56e8a29570a962b95387ebc72bd951
		_app_dir="Antigravity-x64"
		;;
	aarch64)
		distfiles="${_baseurl}/linux-arm/Antigravity.tar.gz>${pkgname}-${version}-arm64.tar.gz"
		checksum=595d7e0fba5c68a480b0124c31bb0d503ebd49d0edaf139459ffc1d1f4a6f3cc
		_app_dir="Antigravity-arm64"
		;;
esac

do_install() {
	# Extract and install app
	vmkdir opt/${pkgname}
	cp -a --no-preserve=ownership "${_app_dir}/." "${DESTDIR}/opt/${pkgname}"
	chmod 755 "${DESTDIR}/opt/${pkgname}/chrome-sandbox"

	# Helper script with flags config support and workarounds for known issues
	cat > antigravity.sh <<EOF
#!/bin/bash
XDG_CONFIG_HOME=\${XDG_CONFIG_HOME:-~/.config}

# Disable core dumps to prevent disk space issues (upstream bug causes crash loops)
ulimit -c 0

# Allow users to override command-line options
if [[ -f \$XDG_CONFIG_HOME/antigravity-flags.conf ]]; then
   ANTIGRAVITY_USER_FLAGS="\$(sed 's/#.*//' \$XDG_CONFIG_HOME/antigravity-flags.conf | tr '\n' ' ')"
fi

# Wayland native support
if [[ \$XDG_SESSION_TYPE == "wayland" ]]; then
   WAYLAND_FLAGS="--ozone-platform=wayland"
fi

# Flags to help with service worker and sandbox issues
STABILITY_FLAGS="--disable-gpu-sandbox --no-sandbox"

exec /opt/${pkgname}/antigravity "\$@" \$WAYLAND_FLAGS \$STABILITY_FLAGS \$ANTIGRAVITY_USER_FLAGS
EOF
	vbin antigravity.sh antigravity

	# Desktop file
	cat > antigravity.desktop <<EOF
[Desktop Entry]
Name=Antigravity
Comment=Agentic development hub from Google
GenericName=Development Tool
Exec=antigravity %U
Type=Application
StartupNotify=true
StartupWMClass=Antigravity
Categories=Development;
EOF
	vinstall antigravity.desktop 644 usr/share/applications

	# License
	vlicense "${DESTDIR}/opt/${pkgname}/LICENSE.electron.txt"
	vlicense "${DESTDIR}/opt/${pkgname}/LICENSES.chromium.html"
}
