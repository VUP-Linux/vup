# Template file for 'gittop'
pkgname=gittop
version=0.5.3
revision=1
archs="x86_64 x86_64-musl aarch64 aarch64-musl"
create_wrksrc=yes
short_desc="Lightweight desktop client for GitHub notifications"
maintainer="AmarBego <begovicamar@proton.me>"
license="AGPL-3.0-only"
homepage="https://github.com/AmarBego/GitTop"
nostrip=yes
noshlibprovides=yes

_baseurl="https://github.com/AmarBego/GitTop/releases/download/v${version}"
case "$XBPS_TARGET_MACHINE" in
	x86_64)
		distfiles="${_baseurl}/gittop-${version}-linux-gnu-x86_64.tar.gz"
		checksum=ee4e9c89f9a48262f1e6b0f09ea74bb59d6288c831ecbdb944c4ea30aaa69cda
		_arch_dir="gittop-${version}-linux-gnu-x86_64"
		;;
	x86_64-musl)
		distfiles="${_baseurl}/gittop-${version}-linux-musl-x86_64.tar.gz"
		checksum=2a618d5931e0f026c0c9bd1fd29bc434a46055a560d60f251657c7cf76565a1b
		_arch_dir="gittop-${version}-linux-musl-x86_64"
		;;
	aarch64)
		distfiles="${_baseurl}/gittop-${version}-linux-gnu-aarch64.tar.gz"
		checksum=c325126dd539b158f7b6f1f43752fb99b9d702b3e56e9b05d9c4dc56f5b4f1a2
		_arch_dir="gittop-${version}-linux-gnu-aarch64"
		;;
	aarch64-musl)
		distfiles="${_baseurl}/gittop-${version}-linux-musl-aarch64.tar.gz"
		checksum=1da06cd096593a1b25fb19256705fd77351a1f6a558a7c6d254ebb2bbc26dd6b
		_arch_dir="gittop-${version}-linux-musl-aarch64"
		;;
esac

do_install() {
	vbin ${_arch_dir}/gittop
	vinstall ${_arch_dir}/gittop.desktop 644 usr/share/applications
	vinstall ${_arch_dir}/gittop.png 644 usr/share/pixmaps
	vlicense ${_arch_dir}/LICENSE.md
}
